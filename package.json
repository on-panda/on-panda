{
  "name": "@on-panda/on-panda",
  "version": "0.3.1",
  "type": "module",
  "main": "./dist/on-panda.es.js",
  "module": "./dist/on-panda.es.js",
  "exports": {
    ".": {
      "import": "./dist/on-panda.es.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config apps/on-panda-web/vite.config.js",
    "build": "vite build",
    "build:web": "vite build --config apps/on-panda-web/vite.config.js",
    "build:core": "pnpm --dir packages/on-panda-core build",
    "publish:core": "pnpm --dir packages/on-panda-core build && pnpm --dir packages/on-panda-core publish",
    "install:core": "pnpm --dir packages/on-panda-core install",
    "analyze": "vite build --mode analyze",
    "analyze:web": "vite build --mode analyze --config apps/on-panda-web/vite.config.js",
    "analyze:core": "cd packages/on-panda-core && pnpm vite build --mode analyze",
    "preview": "vite preview --config apps/on-panda-web/vite.config.js",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.x",
    "@mdit/plugin-katex": "^0.23.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.x",
    "element-plus": "^2.x",
    "highlight.js": "^11.x",
    "json5": "^2.x",
    "katex": "^0.16.x",
    "lz-string": "^1.x",
    "markdown-it": "^14.x",
    "markdown-it-code-copy": "^0.x",
    "openai": "^4.x",
    "pinia": "^2.x",
    "vue": "^3.x",
    "vue-i18n": "^11.x",
    "wavesurfer.js": "^7.x"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.0.5",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "postcss": "^8.5.6",
    "postcss-prefix-selector": "^2.1.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "undici": "^7.16.0",
    "vite": "^5.3.1"
  }
}
